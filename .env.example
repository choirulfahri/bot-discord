# Masukkan Token Bot Discord Anda di sini (Dapatkan di Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# Client ID untuk registrasi Slash Commands (Juga dari Developer Portal)
CLIENT_ID=your_client_id_here

# (Opsional) ID Server / Guild Anda, agar Slash Command langsung muncul saat dites
GUILD_ID=your_guild_id_here
